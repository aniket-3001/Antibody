# MemoryOS — memory_core credentials template. Copy to .env and fill in.
# .env is git-ignored; this template is safe to commit.

MEMORY_CORE_MODE="local"

# ── Option 1: NVIDIA NIM (free tier — recommended) ───────────────────────────
# Get your API key from https://build.nvidia.com
# LLM_PROVIDER=custom
# NVIDIA_NIM_API_KEY=your-nvapi-key-here
# LLM_API_KEY=your-nvapi-key-here
# LLM_MODEL=nvidia_nim/meta/llama-3.3-70b-instruct
# EMBEDDING_PROVIDER=litellm
# EMBEDDING_MODEL=nvidia_nim/nvidia/nv-embedqa-e5-v5
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_API_KEY=your-nvapi-key-here
# COGNEE_SKIP_CONNECTION_TEST=true

# ── Option 2: Anthropic ───────────────────────────────────────────────────────
# LLM_PROVIDER="anthropic"
# LLM_API_KEY="PASTE_ANTHROPIC_KEY_HERE"
# LLM_MODEL="anthropic/claude-sonnet-4-5-20250929"
# EMBEDDING_PROVIDER="fastembed"
# EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
# EMBEDDING_DIMENSIONS="384"

# ── Option 3: OpenAI ──────────────────────────────────────────────────────────
# LLM_PROVIDER="openai"
# LLM_API_KEY="PASTE_OPENAI_KEY_HERE"
# LLM_MODEL="gpt-4o"
# EMBEDDING_PROVIDER="openai"
# EMBEDDING_MODEL="text-embedding-3-large"
# EMBEDDING_DIMENSIONS="3072"
