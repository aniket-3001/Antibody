# Antibody — copy to .env and fill in. All optional: without an LLM key the
# deterministic + semantic matching layer still produces correct verdicts;
# Cognee's cited graph explanations + memify/forget light up once a key is set.

APP_ENV=dev
API_HOST=127.0.0.1
API_PORT=8000
WEB_ORIGIN=http://localhost:5173

# Where Antibody keeps its ops DB + Cognee's embedded stores + model caches.
# Point at a drive with space (Cognee's kuzu/lancedb + fastembed model are large).
DATA_DIR=./.antibody_data

# --- LLM (OpenAI-compatible; read directly by Cognee) ---
# OpenAI:   LLM_PROVIDER=openai   LLM_MODEL=gpt-4o-mini
# DeepSeek: LLM_PROVIDER=custom   LLM_MODEL=deepseek/deepseek-chat  LLM_ENDPOINT=https://api.deepseek.com/v1
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_ENDPOINT=
LLM_API_KEY=

# --- Embeddings: local fastembed (no API key needed) ---
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
