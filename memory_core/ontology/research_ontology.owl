<?xml version="1.0"?>
<!--
  MemoryOS Research Ontology — OWL projection.
  SOURCE OF TRUTH: Docs/ONTOLOGY.md (v1.0). This file is a generated projection;
  if the two disagree, ONTOLOGY.md wins and this file is regenerated.

  Projection of: 10 entity classes + 8 typed object properties with the
  domain/range constraint matrix (ONTOLOGY.md §6.1). Multi-type domains/ranges
  are expressed with owl:unionOf.
-->
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns="http://memoryos.ai/ontology#"
    xml:base="http://memoryos.ai/ontology">

  <owl:Ontology rdf:about="http://memoryos.ai/ontology">
    <rdfs:comment>MemoryOS research knowledge-graph ontology (projection of Docs/ONTOLOGY.md v1.0).</rdfs:comment>
  </owl:Ontology>

  <!-- ============================ Classes (entities) ============================ -->
  <owl:Class rdf:about="#Paper"><rdfs:label>Paper</rdfs:label></owl:Class>
  <owl:Class rdf:about="#Author"><rdfs:label>Author</rdfs:label></owl:Class>
  <owl:Class rdf:about="#Method"><rdfs:label>Method</rdfs:label></owl:Class>
  <owl:Class rdf:about="#Dataset"><rdfs:label>Dataset</rdfs:label></owl:Class>
  <owl:Class rdf:about="#Benchmark"><rdfs:label>Benchmark</rdfs:label></owl:Class>
  <owl:Class rdf:about="#Experiment"><rdfs:label>Experiment</rdfs:label></owl:Class>
  <owl:Class rdf:about="#Hypothesis"><rdfs:label>Hypothesis</rdfs:label></owl:Class>
  <owl:Class rdf:about="#Finding"><rdfs:label>Finding</rdfs:label></owl:Class>
  <owl:Class rdf:about="#ResearchNote"><rdfs:label>ResearchNote</rdfs:label></owl:Class>
  <owl:Class rdf:about="#Topic"><rdfs:label>Topic</rdfs:label></owl:Class>

  <!-- ===================== Object properties (relationships) ===================== -->

  <!-- WRITTEN_BY: Paper -> Author -->
  <owl:ObjectProperty rdf:about="#writtenBy">
    <rdfs:label>WRITTEN_BY</rdfs:label>
    <rdfs:domain rdf:resource="#Paper"/>
    <rdfs:range rdf:resource="#Author"/>
  </owl:ObjectProperty>

  <!-- USES: (Paper | Experiment) -> (Method | Dataset) -->
  <owl:ObjectProperty rdf:about="#uses">
    <rdfs:label>USES</rdfs:label>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="#Paper"/>
        <owl:Class rdf:about="#Experiment"/>
      </owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range>
      <owl:Class><owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="#Method"/>
        <owl:Class rdf:about="#Dataset"/>
      </owl:unionOf></owl:Class>
    </rdfs:range>
  </owl:ObjectProperty>

  <!-- EVALUATES: (Paper | Experiment) -> Benchmark -->
  <owl:ObjectProperty rdf:about="#evaluates">
    <rdfs:label>EVALUATES</rdfs:label>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="#Paper"/>
        <owl:Class rdf:about="#Experiment"/>
      </owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="#Benchmark"/>
  </owl:ObjectProperty>

  <!-- SUPPORTS: (Paper | Finding | Experiment) -> Hypothesis -->
  <owl:ObjectProperty rdf:about="#supports">
    <rdfs:label>SUPPORTS</rdfs:label>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="#Paper"/>
        <owl:Class rdf:about="#Finding"/>
        <owl:Class rdf:about="#Experiment"/>
      </owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="#Hypothesis"/>
  </owl:ObjectProperty>

  <!-- CONTRADICTS: (Paper | Finding | Experiment) -> Hypothesis -->
  <owl:ObjectProperty rdf:about="#contradicts">
    <rdfs:label>CONTRADICTS</rdfs:label>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="#Paper"/>
        <owl:Class rdf:about="#Finding"/>
        <owl:Class rdf:about="#Experiment"/>
      </owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="#Hypothesis"/>
  </owl:ObjectProperty>

  <!-- DERIVED_FROM: (Method | Finding) -> (Method | Paper) -->
  <owl:ObjectProperty rdf:about="#derivedFrom">
    <rdfs:label>DERIVED_FROM</rdfs:label>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="#Method"/>
        <owl:Class rdf:about="#Finding"/>
      </owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range>
      <owl:Class><owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="#Method"/>
        <owl:Class rdf:about="#Paper"/>
      </owl:unionOf></owl:Class>
    </rdfs:range>
  </owl:ObjectProperty>

  <!-- REFERENCES: Paper -> Paper -->
  <owl:ObjectProperty rdf:about="#references">
    <rdfs:label>REFERENCES</rdfs:label>
    <rdfs:domain rdf:resource="#Paper"/>
    <rdfs:range rdf:resource="#Paper"/>
  </owl:ObjectProperty>

  <!-- ABOUT: (Paper | ResearchNote | Experiment) -> Topic -->
  <owl:ObjectProperty rdf:about="#about">
    <rdfs:label>ABOUT</rdfs:label>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="#Paper"/>
        <owl:Class rdf:about="#ResearchNote"/>
        <owl:Class rdf:about="#Experiment"/>
      </owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="#Topic"/>
  </owl:ObjectProperty>

</rdf:RDF>
